{
  "name": "power-di-workspace",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "A lightweight Dependency Injection library. Using es6 and other features, remove unnecessary concepts, easy and convenient to use.",
  "workspaces": [
    "packages/*"
  ],
  "author": "zhang740",
  "license": "MIT",
  "homepage": "https://github.com/zhang740/power-di#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhang740/power-di.git"
  },
  "bugs": {
    "url": "https://github.com/zhang740/power-di/issues"
  },
  "keywords": [
    "di",
    "ts",
    "ioc",
    "react"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm -r build",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "clean": "pnpm -r clean",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@babel/cli": "catalog:",
    "@babel/core": "catalog:",
    "@babel/preset-env": "catalog:",
    "@eslint-react/eslint-plugin": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-test-renderer": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "co": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-test-renderer": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged --allow-empty"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,less}": [
      "prettier --write"
    ]
  }
}
