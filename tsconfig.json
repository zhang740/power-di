{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "jsx": "react",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "isolatedModules": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "preserveConstEnums": true,
    "removeComments": false,
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true,
    "pretty": true,
    "baseUrl": ".",
    "paths": {
      "@power-di/class-loader": [
        "packages/class-loader/src"
      ],
      "@power-di/di": [
        "packages/di/src"
      ],
      "@power-di/aspect": [
        "packages/aspect/src"
      ],
      "@power-di/react": [
        "packages/react/src"
      ],
      "power-di": [
        "packages/legacy-di/src"
      ],
      "power-di/react": [
        "packages/legacy-di/src/react.ts"
      ],
      "power-di/utils": [
        "packages/legacy-di/src/utils.ts"
      ]
    }
  },
  "compileOnSave": true
}
